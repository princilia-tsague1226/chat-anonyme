<section class="room-container">

    <header class="room-header">
        <h2><?= htmlspecialchars($title) ?></h2>
        <?php if (isset($room) && is_object($room)): ?>
            <span class="date-creation">Créé le : <?= $room->getCreatedAt() ?></span>
        <?php endif; ?>
    </header>

    <div class="chat-window">
        <ul class="message-list">
            <?php if (isset($rooms) && !empty($rooms)): ?>
                <?php foreach ($rooms as $room): ?>
                    <li class="message-item">
                        <span class="message-date">[<?= $room->getCreatedAt() ?>]</span>
                        <span class="message-content"><?= htmlspecialchars($room->getContent()) ?></span>
                    </li>
                <?php endforeach; ?>
            <?php else: ?>
                <p class="empty-chat">Aucun message dans ce salon. Soyez le premier à écrire !</p>
            <?php endif; ?>
        </ul>
    </div>

    <footer class="chat-footer">
        <form action="index.php?action=addPost" method="POST" class="message-form">
            <input type="hidden" name="room_id" value="<?= $_GET['id'] ?? '' ?>">
            
            <input type="text" name="content" placeholder="Message..." required>
            <button type="submit">Envoyer</button>
        </form>
    </footer>

</section>